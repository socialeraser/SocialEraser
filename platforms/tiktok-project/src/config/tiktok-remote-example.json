        "[data-e2e='user-liked-item']",
        "[data-e2e='user-favorite-item']",
        "[data-e2e='user-following-item']",
        "article"
      ],
      "_comment_videoMoreButtons": "DEPRECATED for videos (TikTok 2026 hides 'More' on profile cards). Kept as fallback for reposts when DOM still has them. Video deletion now uses videoActionButton + videoStudioUrl.",
      "videoMoreButtons": [
        "[data-e2e='video-more']",
        "button[aria-label='More']",
        "button[aria-label*='More']",
        "button[aria-label*='更多']",
        "button[aria-label*='詳細']",
