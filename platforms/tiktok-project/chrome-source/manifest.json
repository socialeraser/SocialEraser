{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "description": "__MSG_ext_description__",
  "version": "0.1.0",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://tiktok.com/*",
    "*://www.tiktok.com/*",
    "https://storage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://tiktok.com/*", "*://www.tiktok.com/*"],
      "js": ["i18n.js", "tiktok-automation.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}
