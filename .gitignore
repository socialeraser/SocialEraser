# Dependencies
node_modules/
.pnpm-store/

# Production build
dist/
build/
www/
# Monorepo build outputs (regenerated by `npm run build`)
# Capacitor webDir for each platform
/platforms/*/www/
# Capacitor native assets (synced from platforms/*/www/)
/platforms/*/android/app/src/main/assets/public/
/platforms/*/ios/App/public/
# Chrome/Firefox extensions are synced from platforms/*/src
# Ignore all contents, then re-include the chrome-specific source files.
# (manifest.json + background.js live in extensions/chrome-x/ as the
# canonical source — everything else there is build output.)
/extensions/chrome-x/*
!/extensions/chrome-x/manifest.json
!/extensions/chrome-x/background.js
# Future Firefox / Edge ports use the same pattern
/extensions/firefox-x/*
/extensions/edge-x/*

# Gradle cache
.gradle/

# Operating System files
.DS_Store
Thumbs.db

# IDEs and editors
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
*.log

skill.md