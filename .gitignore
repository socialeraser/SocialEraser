# Dependencies
node_modules/
.pnpm-store/

# Production build
dist/
build/
www/
# Monorepo build outputs (regenerated by `npm run build`)
# Capacitor webDir for each platform
/platforms/*/www/
# Capacitor native assets (synced from platforms/*/www/)
/platforms/*/android/app/src/main/assets/public/
/platforms/*/ios/App/public/
# Chrome/Firefox/Edge browser extensions are 100% build output
# (synced from platforms/*/src + scripts + *-source/).
/extensions/chrome-x/
/extensions/firefox-x/
/extensions/edge-x/

# Gradle cache
.gradle/

# Operating System files
.DS_Store
Thumbs.db

# IDEs and editors
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
*.log

skill.md