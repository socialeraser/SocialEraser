# Dependencies
node_modules/
.pnpm-store/

# Production build
dist/
build/
www/
# Monorepo build outputs (regenerated by `npm run build`)
# Capacitor webDir for each platform
/platforms/*/www/
# Capacitor native assets (synced from platforms/*/www/)
#   注意：iOS 项目结构有 `ios/App/App/public`（双 App，新版 Capacitor 3+）
#   和 `ios/App/public`（单 App，老版本）两种，gitignore 的 * 不跨 /，
#   所以需要两个模式分别覆盖
/platforms/*/android/app/src/main/assets/public/
/platforms/*/ios/App/public/
/platforms/*/ios/App/App/public/
# Chrome and Edge browser extensions are 100% build output
# (synced from platforms/*/src + scripts + chrome-source/; chrome-source
# also produces extensions/edge-x/ via BROWSER_ALIASES in sync-shared.js).
/extensions/chrome-x/
/extensions/chrome-tiktok/
/extensions/edge-x/
/extensions/edge-tiktok/

# Gradle cache
.gradle/

# Operating System files
.DS_Store
Thumbs.db

# IDEs and editors
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
*.log

# Secrets / credentials (defense in depth)
.env
.env.*
*.pem
*.key
secrets.json

skill.md