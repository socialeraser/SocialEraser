        "fr": [
          { "type": "text", "value": "Se connecter" },
          { "type": "text", "value": "Créer votre compte" },
          { "type": "selector", "value": "[data-testid='loginButton']" }
        ]
      },
      "loggedInElements": [
        { "type": "selector", "value": "a[href='/compose/post']" },
        { "type": "selector", "value": "a[href='/home']" },
        { "type": "selector", "value": "a[href^='/i/chat']" },
        { "type": "selector", "value": "a[href^='/notifications']" },
        { "type": "selector", "value": "[data-testid^='AppTabBar_']" },
        { "type": "selector", "value": "[data-testid^='SideNav_AccountSwitcher']" },
        { "type": "selector", "value": "[data-testid^='UserAvatar-Container']" }
      ]
    },
    "like": {
      "container": "[data-testid='tweet'], [data-testid='cellInnerDiv']",
      "unlikeButtons": [
        "[data-testid='unlike']",
        "[data-testid='unlike-react']",
        "button[aria-label*='Liked']",
        "button[aria-label*='Unlike']",
        "button[aria-label*='喜欢了']",
        "button[aria-label*='已喜歡']",
        "button[aria-label*='いいねしました']",
        "button[aria-label*='마음에 들어 함']",
        "button[aria-label*='Marcó como Me gusta']",
        "button[aria-label*='Me gusta']",
        "button[aria-label*='Gefällt mir']",
        "button[aria-label*=\"J'aime\"]"
      ]
    },
    "bookmark": {
      "container": "[data-testid='tweet']",
      "removeButtons": [
        "[data-testid='removeBookmark']",
        "button[aria-label*='Bookmarked']",
        "button[aria-label*='已加入书签']",
        "button[aria-label*='已加入書籤']",
        "button[aria-label*='ブックマークに追加済み']",
