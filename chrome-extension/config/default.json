        "button[aria-label*='Lesezeichen']",
        "button[aria-label*='signets']"
      ]
    },
    "following": {
      "container": "[data-testid='cellInnerDiv']",
      "unfollowButtons": [
        "[data-testid$='-unfollow']",
        "button[aria-label*='Following']",
        "button[aria-label*='Unfollow']",
        "button[aria-label*='正在关注']",
        "button[aria-label*='正在跟隨']",
        "button[aria-label*='フォロー中']",
        "button[aria-label*='팔로잉']",
        "button[aria-label*='Siguiendo']",
        "button[aria-label*='Folge ich']",
        "button[aria-label*='Abonné']"
      ],
      "confirmButton": "[data-testid='confirmationSheetConfirm']"
    },
    "common": {
      "_comment": "4 种清理类型共用的 DOM 选择器 —— X 改版只改这里即可（2026-XX-XX 抽出）",
      "confirmButton": ["[data-testid='confirmationSheetConfirm']"],
      "articleContainers": ["[data-testid='tweet']", "[data-testid='cellInnerDiv']", "article"],
      "timeElement": ["time[datetime]"],
      "tweetText": ["[data-testid='tweetText']"],
      "userInfo": {
        "userCell": ["[data-testid='UserCell']", "[data-testid='userCell']"],
        "userName": ["[data-testid='User-Name']", "[data-testid='UserName']"],
        "userDescription": ["[data-testid='UserDescription']"]
      }
    },
    "tweet": {
      "_comment": "推文特有的选择器 —— 加上 common 中没覆盖的部分（2026-XX-XX 合并）",
      "container": "[data-testid='tweet']",
      "moreButtons": [
        "[data-testid='more']",
        "[data-testid='caret']",
        "button[aria-label='More']",
        "button[aria-label*='More']",
        "button[aria-label*='更多']",
        "button[aria-label*='もっと見る']",
        "button[aria-label*='더 보기']",
        "button[aria-label*='Mehr']",
        "button[aria-label*='Plus']",
        "button[aria-label*='Más opciones']"
      ],
      "confirmButton": "[data-testid='confirmationSheetConfirm']",
      "socialContext": ["[data-testid='socialContext']"],
      "unreTweetButtons": [
        "[data-testid='unretweet']",
        "[data-testid='undoRepost']",
        "button[aria-label*='Reposted']",
        "button[aria-label*='已转帖']",
        "button[aria-label*='已轉發']",
        "button[aria-label*='リポストしました']",
        "button[aria-label*='재게시함']",
        "button[aria-label*='Reposteado']",
        "button[aria-label*='Repostet']",
        "button[aria-label*='Reposté']"
      ],
      "unretweetConfirmButtons": ["[data-testid='unretweetConfirm']"],
      "retweetButtonInCard": [
        "[data-testid='unretweet']",
        "[data-testid='undoRepost']",
        "button[aria-label*='Reposted']",
        "button[aria-label*='已转帖']",
        "button[aria-label*='已轉發']",
        "button[aria-label*='リポストしました']",
        "button[aria-label*='재게시함']",
        "button[aria-label*='Reposteado']",
