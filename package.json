{
  "name": "social-eraser-monorepo",
  "version": "1.0.0",
  "description": "SocialEraser — multi-platform batch-delete tools (X, TikTok, YouTube, Facebook)",
  "private": true,
  "workspaces": [
    "packages/*",
    "platforms/*"
  ],
  "scripts": {
    "sync": "node scripts/sync-shared.js --no-cap",
    "build": "node scripts/sync-shared.js",
    "start": "npm run build && cd platforms/x-project && npx cap run android",
    "dev:website": "npm --workspace @social-eraser/marketing-website run dev",
    "android:open": "cd platforms/x-project && npx cap open android",
    "test": "npm run sync && node scripts/run-verify.js",
    "verify": "node scripts/run-verify.js",
    "verify:single": "node scripts/run-verify.js --single",
    "deploy:website": "./scripts/deploy-website.sh"
  },
  "keywords": [
    "twitter",
    "tiktok",
    "delete",
    "batch",
    "cleanup"
  ],
  "author": "",
  "license": "MIT"
}
